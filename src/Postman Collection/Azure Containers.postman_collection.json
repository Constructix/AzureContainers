    {
      "name": "ServiceBusFunctionsInContainers",
      "item": [
        {
          "name": "Localhost",
          "item": [
            {
              "name": "SubmitNewOrderToServiceBusQueue",
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\r\n    \"Customer\": {\r\n        \"firstName\":\"Richard\",\r\n        \"lastName\":\"Jones\"\r\n    }\r\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "http://localhost:7134/api/NewOrder",
                  "protocol": "http",
                  "host": [
                    "localhost"
                  ],
                  "port": "7134",
                  "path": [
                    "api",
                    "NewOrder"
                  ]
                }
              },
              "response": []
            }
          ]
        },
        {
          "name": "SubmitNewOrderToServiceBusQueue Copy",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest(\"https://api.ipify.org?format=json\", (err, res) => {\r",
                  "    if (!err) {\r",
                  "        const ip = res.json().ip;\r",
                  "        pm.environment.set(\"clientIP\", ip);\r",
                  "        console.log(\"Client IP:\", ip);\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "{{clientIP}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"Customer\": {\r\n        \"firstName\":\"Richard\",\r\n        \"lastName\":\"Jones\",\r\n        \"Message\": \"2nd attempt - Sending message via Azure Function which has been deployed. \"\r\n    }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{AzureContainer}}/api/NewOrder",
              "host": [
                "{{AzureContainer}}"
              ],
              "path": [
                "api",
                "NewOrder"
              ]
            }
          },
          "response": []
        }
      ]
    },
